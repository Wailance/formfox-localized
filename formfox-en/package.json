{
  "name": "formfox-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:popup": "esbuild src/popup.ts --bundle --platform=browser --target=es2020 --outfile=dist/popup.js",
    "build:background": "esbuild src/background.ts --bundle --platform=browser --target=es2020 --outfile=dist/background.js",
    "build:content": "esbuild src/content.ts --bundle --platform=browser --target=es2020 --outfile=dist/content.js",
    "build": "npm run build:popup && npm run build:background && npm run build:content"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.283",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}

