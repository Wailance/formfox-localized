{
  "manifest_version": 3,
  "name": "FormFox",
  "version": "0.1.0",
  "description": "Сохраняйте профили реквизитов и заполняйте формы одним кликом.",
  "action": {
    "default_title": "FormFox",
    "default_popup": "public/popup.html"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "dist/background.js"
  }
}
